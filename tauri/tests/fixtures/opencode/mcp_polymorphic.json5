{
  $schema: "https://opencode.ai/config.json",
  model: "gateway/gpt-5.4",
  small_model: "gateway/gpt-5.4-mini",
  disabled_providers: ["fallback"],
  autoupdate: {
    channel: "latest",
  },
  permission: true,
  formatter: ["prettier", "--write"],
  mcp: {
    filesystem: {
      type: "local",
      command: ["npx", "@modelcontextprotocol/server-filesystem", "."],
      enabled: true,
      environment: {
        LOG_LEVEL: "debug",
      },
    },
    remoteSearch: {
      type: "remote",
      url: "https://mcp.example.com/sse",
      oauth: false,
      enabled: true,
    },
  },
  provider: {
    gateway: {
      npm: "@ai-sdk/openai-compatible",
    },
  },
  customTopLevelObject: {
    nested: ["a", "b"],
  },
}
